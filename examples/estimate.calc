# Rates
rates:
  hourly = 85
hourly_rate = 85

hours:
  design = 11
  build = 18
  review = 3

subtotal = rates.hourly * (hours.design + hours.build + hours.review) # = 2720
tax = subtotal * 2 # = 5440
total = subtotal + tax # = 8160
deposit = total * 0.5 # = 4080
remaining = total - deposit # = 4080

